# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-side only — DO NOT prefix with VITE_ (would expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend (transactional email)
# Used by api/contact.js for contact-form submissions AND by the backup cron
# (api/admin/event.js ?resource=backup-run) for emailing CSV backups.
RESEND_API_KEY=your_resend_api_key

# Vercel cron protection. Vercel auto-injects Authorization: Bearer <secret>
# on scheduled cron requests when this env var is set; the backup-run handler
# rejects any request that does not match. Generate a long random string.
CRON_SECRET=your_cron_secret

# Sentry (error + performance monitoring)
# VITE_SENTRY_DSN is the public DSN read by the browser at runtime (src/main.jsx);
# Sentry no-ops silently if it is unset.
VITE_SENTRY_DSN=your_sentry_dsn
# SENTRY_DSN is server-side only and lets Vercel API routes report unexpected
# server errors without exposing extra runtime config to the browser.
SENTRY_DSN=your_sentry_dsn
# SENTRY_AUTH_TOKEN is server-side only, used at build time by the Sentry Vite
# plugin (vite.config.js) to upload source maps. Uploads are disabled unless
# SENTRY_UPLOAD_SOURCEMAPS=true is also set.
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_UPLOAD_SOURCEMAPS=false

# Upstash Redis (rate limiting)
# Read via Redis.fromEnv() by public and authenticated API rate limiters. Both
# are required in production. Server-side only.
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
